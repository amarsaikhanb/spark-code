{
  "model_name": "Qwen/Qwen2.5-Coder-3B-Instruct",
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "lora_targets": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "max_train_problems": 200,
  "eval_mbpp_heldout": true,
  "mbpp_eval_size": 100,
  "use_mbpp_challenge_tests": true,
  "prompt_style": "complete_function",
  "use_frontier_filter": false,
  "frontier_pool_size": 300,
  "frontier_k": 4,
  "load_frontier_path": "",
  "num_iterations": 3,
  "num_rollouts": 4,
  "adaptive_rollouts": true,
  "max_adaptive_rollouts": 8,
  "adaptive_extra_step": 2,
  "max_new_tokens": 512,
  "temperature": 1.0,
  "top_p": 0.98,
  "partial_rewards": true,
  "syntax_penalty": -0.2,
  "runtime_penalty": -0.1,
  "timeout_penalty": -0.3,
  "wrong_answer_floor": 0.0,
  "grpo_lr": 5e-06,
  "grpo_grad_accum": 4,
  "clip_ratio": 0.2,
  "kl_coeff": 0.01,
  "max_grad_norm": 1.0,
  "aux_loss_scale": 0.1,
  "aux_epochs": 1,
  "aux_micro_batch": 2,
  "aux_max_len": 1024,
  "aux_max_pointwise": 200,
  "aux_max_pairwise": 200,
  "aux_max_reflection": 400,
  "aux_weight_pointwise": 0.0,
  "aux_weight_pairwise": 0.1,
  "aux_weight_reflection": 1.0,
  "refl_self_fix_temperature": 0.7,
  "reflection_target_mode": "correct_or_canonical",
  "sft_warmup": false,
  "sft_loss_scale": 0.4,
  "sft_epochs": 1,
  "sft_max_examples": 200,
  "eval_num_samples": 5,
  "eval_temperature": 0.2,
  "eval_top_p": 0.95,
  "reflection_eval_problems": 164,
  "exec_timeout": 10,
  "exec_memory_mb": 2048,
  "seed": 42,
  "device": "cuda",
  "output_dir": "./output_C_light_3B",
  "wandb_project": "spark-code",
  "wandb_enabled": true,
  "hf_repo_id": "",
  "hf_token": ""
}
